{
  "name": "skillzs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "ingest": "tsx scripts/ingest-local.ts",
    "backfill:diptychs": "node scripts/backfill-diptychs.mjs",
    "backfill:avatars": "node scripts/backfill-avatars.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ratchet": "vitest run --coverage --coverage.thresholds.autoUpdate=true",
    "ratchet": "npm run test:coverage:ratchet",
    "quality": "npm run lint && npm run test:coverage"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "gray-matter": "^4.0.3",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.6"
  }
}
