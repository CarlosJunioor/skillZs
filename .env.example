# Supabase project - Settings > API
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...           # public, safe to ship to client
SUPABASE_SERVICE_KEY=eyJhbGciOi...        # server-only; never expose

# Public production URL used for canonical URLs, sitemap, robots.txt, and social cards.
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# GitHub PAT (no scopes needed for public repo reads). Lifts rate limit 60 to 5000/hr.
GITHUB_TOKEN=

# Random string used to hash voter IPs (sha256(ip + salt + day)).
# Rotate quarterly to flush any tracking surface.
IP_HASH_SALT=change-me-to-random-string

# Shared secret protecting Vercel cron routes.
# Send secrets only as `Authorization: Bearer $SECRET` or `x-cron-secret`.
CRON_SECRET=change-me-too

# Required for /api/cron/generate-covers. This endpoint is manual/expensive and
# does not accept the global CRON_SECRET fallback.
COVER_CRON_SECRET=change-me-too-cover

# Required for manual/admin routes (/api/regen/<slug>, /api/admin/*).
# Scheduled diptych/avatar/building cron routes also accept CRON_SECRET because
# Vercel injects it automatically for configured cron jobs.
DIPTYCH_CRON_SECRET=change-me-too-diptych

# OpenAI key for AI cover + diptych generation (gpt-image-1 for images,
# gpt-4o-mini for the tagline/before/after JSON pass).
OPENAI_API_KEY=

# Vercel Blob token for hosting generated covers AND diptychs.
# Vercel dashboard -> Storage -> Create Blob store -> .env.local tab -> copy.
BLOB_READ_WRITE_TOKEN=
