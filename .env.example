# Supabase project - Settings > API
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...           # public, safe to ship to client
SUPABASE_SERVICE_KEY=eyJhbGciOi...        # server-only; never expose

# GitHub PAT (no scopes needed for public repo reads). Lifts rate limit 60 to 5000/hr.
GITHUB_TOKEN=

# Random string used to hash voter IPs (sha256(ip + salt + day)).
# Rotate quarterly to flush any tracking surface.
IP_HASH_SALT=change-me-to-random-string

# Shared secret protecting Vercel cron routes.
# Send secrets only as `Authorization: Bearer $SECRET` or `x-cron-secret`.
CRON_SECRET=change-me-too

# Optional: isolate the expensive manual cover-generation endpoint from ingest.
COVER_CRON_SECRET=

# OpenAI key for AI cover generation (gpt-image-1).
# Top-N most-popular skills get a custom cover via /api/cron/generate-covers.
OPENAI_API_KEY=

# Vercel Blob token for hosting generated covers.
# Vercel dashboard -> Storage -> Create Blob store -> .env.local tab -> copy.
BLOB_READ_WRITE_TOKEN=
